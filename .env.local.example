# =============================================================================
# StockViz Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# --- Supabase ------------------------------------------------------------------
# For local development with Docker, see supabase/.env.local.example
# For hosted Supabase, use your project credentials from the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:64321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key - required for server-side operations (cache cleanup, etc.)
# DO NOT commit this to version control. Get from Supabase Dashboard > Settings > API.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- AI / Gemini ---------------------------------------------------------------
# Used by the AI summary service (lib/ai/ once extracted).
GEMINI_API_KEY=your-gemini-api-key

# --- Market Data ---------------------------------------------------------------
# API key for market data provider (Alpha Vantage, Polygon, etc.)
# Used by lib/market/ services once extracted.
MARKET_DATA_API_KEY=your-market-data-api-key

# --- Application ---------------------------------------------------------------
# Optional: override the default port for local development
# PORT=3000
